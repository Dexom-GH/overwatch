# Overwatch secrets & env overrides. Copy to `.env` (gitignored) and fill in.
# NEVER commit real secrets, and never put secret VALUES in configs/*.yaml — the
# YAML names which env var holds a secret (e.g. output.slack.webhook_env), the
# value is resolved from here / the process environment. A real process env var
# wins over this file. The app fails loudly at startup if a REQUIRED secret is
# missing (config.loader.validate_secrets, #41).

# --- Required secrets ------------------------------------------------------

# Slack incoming webhook for alerts (output/slack.py; named by
# output.slack.webhook_env). REQUIRED — the app refuses to start without it.
SLACK_WEBHOOK=

# --- Optional secrets ------------------------------------------------------

# Per-camera RTSP credentials for multi-source capture (#30). One entry per
# camera id; required only once an RTSP source is configured (ZED-only V1 needs
# none). Pattern (uncomment + fill per camera as #30 lands):
# RTSP_CRED_CAM_FENCE_N=username:password
# RTSP_CRED_CAM_BARN_S=username:password

# --- Non-secret overrides --------------------------------------------------

# ZED capture: optional override of capture.source_id (env wins over YAML).
# ZED_SOURCE_ID=zed-0

# Bus endpoint is NOT a secret — it lives in configs/default.yaml (bus.endpoint).
# ADR-0001 chose the hybrid ZeroMQ + SQLite EventStore bus, so there is NO Redis
# in V1 and no REDIS_URL secret. (Redis is only a dormant fallback the ADR may
# revisit; it would be added here then.)
