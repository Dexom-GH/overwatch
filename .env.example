# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Slack incoming webhook for alerts (output/slack.py)
SLACK_WEBHOOK=

# Message bus: ADR-0001 chose ZeroMQ (hybrid). The endpoint is NOT a secret and
# lives in configs/default.yaml (bus.endpoint), so it is not set here.
# REDIS_URL is only needed on the Redis fallback path (bus.transport: redis,
# bus.url_env: REDIS_URL) — a secret resolved from this var.
# REDIS_URL=redis://localhost:6379/0

# ZED capture: optional override of capture.source_id. Commented out by default —
# if set, it overrides the YAML value (env wins over file). Uncomment to use.
# ZED_SOURCE_ID=zed-0
