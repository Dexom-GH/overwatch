# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Slack incoming webhook for alerts (output/slack.py)
SLACK_WEBHOOK=

# Message bus URL (consumed once ADR-0001 picks a transport)
REDIS_URL=redis://localhost:6379/0

# ZED capture (optional overrides; see configs/default.yaml)
ZED_SOURCE_ID=zed-0
